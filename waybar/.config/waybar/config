{
    "layer": "top",
    "position": "top",
    "modules-left": ["sway/workspaces", "sway/mode", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/recorder","sway/language", "tray", "idle_inhibitor", "pulseaudio", "temperature", "custom/cpu_speed", "battery", "custom/powermenu"],
    "sway/mode": {
        "format": "ΎΒΦΎΕΖ {}"
    },
    "sway/workspaces": {
        "disable-scroll": true,
        "disable-markup": false,
        "format": "{icon}",
        "format-icons": {
            "1": "1 <span> ΎΚρ</span>",
            "2": "2 <span> ΎΕι</span>",
            "3": "3 <span> ΎΕκ</span>",
            "4": "4 <span> ΎΗα</span>",
            "5": "5",
            "6": "6",
            "7": "7",
            "8": "8",
            "9": "9",
            "10": "10",
        }
    },
    "sway/window": {
        "max-length": 60,
        "tooltip": false
        // "format": "( {} )"
    },
    "clock": {
        "format": "{:%a %d %b - %H:%M}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><big>{calendar}</big></tt>",
        "on-click": "gnome-calendar"
    },
    "custom/cpu_speed": {
        "interval": 10,
        "return-type": "json",
        "exec": "~/.config/waybar/modules/cpu_speed.sh",
        "format": "<span>{icon}</span>  {}",
        "format-icons": ["ΎΜδ"],
        "escape": true,
    },
    "sway/language": {
        "format": "<span>ΏθΠ│Ύ╕Π</span> {}",
        "tooltip-format": "{long}",
        "on-click": "swaymsg input 'type:keyboard' xkb_switch_layout next"
    },
    "custom/powermenu": {
        "return-type": "json",
        "exec": "~/.config/waybar/modules/powermenu.sh",
        "format": "<span>{icon}</span>  {}",
        "format-icons": ["ΎΑΣ"],
        "interval": 3600,
        "escape": true,
        "on-click": "swaynag -t warning -m 'End session?' -b 'Yes, exit sway' 'swaymsg exit'"
    },
    "custom/recorder": {
		"format": "ΎΑ╜",
		"return-type": "json",
		"interval": 4,
		"exec": "echo '{\"class\": \"recording\"}'",
		"exec-if": "pgrep wf-recorder"
	},
    "battery": {
        "format": "<span>{icon}</span>  {capacity}% - {time}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "format-time": "{H}h{M}m",
        "format-charging": "<span>ΎΔπ</span>  <span>{icon}</span>  {capacity}% - {time}",
        "format-full": "<span>ΎΔπ</span>  <span>{icon}</span>  Charged",
        "interval": 30,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "tooltip": false,
        "on-click": "gnome-power-statistics"
    },
    "network": {
        "format": "{icon}",
        "format-alt": "{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-right",
        "format-wifi": "<span>ΎΘτ</span>  {essid} ({signalStrength}%)",
        "format-ethernet": "ΎΔΒ {ifname}",
        "format-disconnected": "έγι Disconnected",
        "on-click": "terminator -e ~/sway/scripts/network-manager",
        // "on-click": "gnome-control-center wifi",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "<span>{icon:2}</span>{volume:4}%",
        "format-alt": "<span>{icon:2}</span> {volume:4}%",
        "format-alt-click": "click-right",
        "format-muted": "<span>Ύγσ</span>",
        "format-icons": {
            "headphone": ["ΎΑξ ΎΑο", "ΎΑξ ΎΑπ", "ΎΑξ ΎΑπ", "ΎΑξ ΎΑρ"],
            "default": ["ΎΑο", "ΎΑπ", "ΎΑπ", "ΎΑρ"]
        },
        "scroll-step": 2,
        "on-click": "gnome-control-center sound",
        "tooltip": false
    },
    "custom/storage": {
        "format": "{} ΎΓι",
        "format-alt": "{percentage}% ΎΓι",
        "format-alt-click": "click-right",
        "return-type": "json",
        "interval": 60,
        "exec": "~/.config/waybar/modules/storage.sh"
    },
    "backlight": {
        "format": "{icon}",
        "format-alt": "{percent}% {icon}",
        "format-alt-click": "click-right",
        "format-icons": ["ΎΔτ", "Ύβ▓"],
        "on-scroll-down": "light -A 1",
        "on-scroll-up": "light -U 1"
    },
    "temperature": {
        "format": "<span>Ύζτ</span> {temperatureC:3}┬░C",
        //"hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon3/temp1_input",
        "hwmon-path": "/sys/class/thermal/thermal_zone10/temp",
        //"on-click": "terminator -e 'watch -n1 sensors'"
        "on-click": "psensor"
    },
    "custom/weather": {
        "format": "{}",
        "format-alt": "{alt}: {}",
        "format-alt-click": "click-right",
        "interval": 1800,
        "return-type": "json",
        "exec": "~/.config/waybar/modules/weather.sh",
        "exec-if": "ping wttr.in -c1",
        // "on-click": "terminator -p Small -e 'bash -c \"curl -s https://en.wttr.in; read line\"'"
        "on-click": "gnome-weather"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-alt": "{icon} idle {status}",
        "format-alt-click": "click-right",
        "format-icons": {
            "activated": "<span>ΎΠΒ</span>",
            "deactivated": "<span>ΎΑμ</span>"
        },
        "tooltip": false
    },

    "tray": {
        "icon-size": 18,
        "spacing": 18
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 14,
        "icon-theme": "Numix-Circle",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    }
}
